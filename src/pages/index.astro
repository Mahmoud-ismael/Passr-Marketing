---
import Marketing from '../layouts/Marketing.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import Problem from '../components/sections/Problem.astro';
import Features from '../components/sections/Features.astro';
import Regulation from '../components/sections/Regulation.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import PassportPreview from '../components/sections/PassportPreview.astro';
import CTA from '../components/sections/CTA.astro';
---

<Marketing 
	title="Industrial-Grade Digital Passports" 
	description="Passr enables businesses to issue, manage, and verify digital passports with unmatched security and precise industrial clarity.">
	
	<Hero />
	<Stats />
	<Problem />
	<Features />
	<Regulation />
	<HowItWorks />
	<PassportPreview />
	<CTA />

	<!-- Other sections will go here -->
	<section class="section-container border-t border-border-subtle bg-void">
		<div class="container-inner text-center">
			<h2 class="font-display font-bold text-[var(--text-h2)] text-white mb-16 uppercase tracking-[-0.02em] leading-[1.0]">Trusted by global infrastructure partners</h2>
			<div class="flex flex-wrap justify-center gap-16 opacity-30 grayscale contrast-125">
				<div class="h-8 w-40 border border-metal/50 flex items-center justify-center font-mono text-[11px] uppercase tracking-[0.12em]">PARTNER_ALPHA</div>
				<div class="h-8 w-40 border border-metal/50 flex items-center justify-center font-mono text-[11px] uppercase tracking-[0.12em]">PROTOCOL_02</div>
				<div class="h-8 w-40 border border-metal/50 flex items-center justify-center font-mono text-[11px] uppercase tracking-[0.12em]">GS1_CERTIFIED</div>
				<div class="h-8 w-40 border border-metal/50 flex items-center justify-center font-mono text-[11px] uppercase tracking-[0.12em]">EU_ESPR_V8</div>
			</div>
		</div>
	</section>
</Marketing>
