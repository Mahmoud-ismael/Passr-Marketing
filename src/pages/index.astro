---
import Marketing from '../layouts/Marketing.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import Problem from '../components/sections/Problem.astro';
import Features from '../components/sections/Features.astro';
import Regulation from '../components/sections/Regulation.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import PassportPreview from '../components/sections/PassportPreview.astro';
import CTA from '../components/sections/CTA.astro';
---

<Marketing 
	title="Industrial-Grade Digital Passports" 
	description="Passr enables businesses to issue, manage, and verify digital passports with unmatched security and precise industrial clarity.">
	
	<Hero />
	<Stats />
	<Problem />
	<Features />
	<Regulation />
	<HowItWorks />
	<PassportPreview />
	<CTA />

	<!-- Other sections will go here -->
	<section class="py-24 border-t border-border-default">
		<div class="container mx-auto px-6 text-center">
			<h2 class="font-display font-bold text-3xl mb-16 uppercase tracking-tight">Trusted by global infrastructure partners</h2>
			<div class="flex flex-wrap justify-center gap-16 opacity-30 grayscale contrast-125">
				<div class="h-6 w-32 border border-metal/50 flex items-center justify-center font-mono text-[10px] uppercase">PARTNER_ALPHA</div>
				<div class="h-6 w-32 border border-metal/50 flex items-center justify-center font-mono text-[10px] uppercase">PROTOCOL_02</div>
				<div class="h-6 w-32 border border-metal/50 flex items-center justify-center font-mono text-[10px] uppercase">GS1_CERTIFIED</div>
				<div class="h-6 w-32 border border-metal/50 flex items-center justify-center font-mono text-[10px] uppercase">EU_ESPR_V8</div>
			</div>
		</div>
	</section>
</Marketing>
