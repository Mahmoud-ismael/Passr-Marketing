---
import Marketing from '../layouts/Marketing.astro';
import SectionLabel from '../components/shared/SectionLabel.astro';
import Button from '../components/shared/Button.astro';
import Badge from '../components/shared/Badge.astro';
import { CheckCircle, XCircle, ArrowRight } from '@lucide/astro';

const plans = [
  {
    name: 'STARTER',
    price: '€149',
    description: 'Perfect for small brands starting their compliance journey.',
    features: [
      { label: 'Up to 50 SKUs', included: true },
      { label: '1 Admin + 1 Editor seat', included: true },
      { label: 'CSV catalog import', included: true },
      { label: 'GS1 QR code generation', included: true },
      { label: 'PFAS compliance locker', included: true },
      { label: 'Public passport pages', included: true },
      { label: 'Basic scan analytics', included: true },
      { label: 'Data escrow export', included: true },
      { label: 'Team access (3+ users)', included: false },
      { label: 'API access', included: false },
      { label: 'Priority support', included: false },
    ],
    cta: 'START STARTER',
    variant: 'secondary' as const,
  },
  {
    name: 'GROWTH',
    price: '€349',
    description: 'Full compliance automation for growing activewear brands.',
    popular: true,
    features: [
      { label: 'Up to 500 SKUs', included: true },
      { label: 'Unlimited team seats', included: true },
      { label: 'All user roles (Admin, Editor, Viewer)', included: true },
      { label: 'Full passport analytics + geography data', included: true },
      { label: 'Regulatory update feed', included: true },
      { label: 'REST API access', included: true },
      { label: 'Email compliance alerts', included: true },
      { label: 'Priority email support', included: true },
      { label: 'Custom passport domain', included: false },
      { label: 'White-glove onboarding', included: false },
    ],
    cta: 'START GROWTH',
    variant: 'primary' as const,
  },
  {
    name: 'SCALE',
    price: '€799',
    description: 'Enterprise-grade infrastructure for global brand groups.',
    features: [
      { label: 'Unlimited SKUs', included: true },
      { label: 'Custom passport subdomain', included: true },
      { label: 'White-glove onboarding call', included: true },
      { label: '99.9% uptime SLA', included: true },
      { label: 'IPFS backup (decentralized archive)', included: true },
      { label: 'Dedicated Slack support channel', included: true },
    ],
    cta: 'START SCALE',
    variant: 'secondary' as const,
  },
];

const faqs = [
  {
    q: 'Does Passr handle EU VAT on my subscription?',
    a: 'Yes. Passr uses Dodo Payments as Merchant of Record. EU VAT is calculated and handled automatically based on your billing country.',
  },
  {
    q: 'What happens to my data if I cancel?',
    a: 'You own your data. Before cancelling, download your full legal archive from Settings → Data & Export. Your certificates, product data, and compliance records are yours.',
  },
  {
    q: 'Is Passr itself GDPR compliant?',
    a: 'Yes. All data is stored in EU-region infrastructure (Frankfurt, Germany). We have a Data Processing Agreement available. See our DPA page.',
  },
  {
    q: 'Can I upgrade or downgrade my plan?',
    a: 'Yes, at any time. Upgrades take effect immediately. Downgrades take effect at the next billing cycle.',
  },
  {
    q: 'Is the GS1 Digital Link format really compliant?',
    a: 'Yes. Passr generates URLs in the exact GS1 Digital Link standard format: https://verify.passr.eu/01/{GTIN}. This is the format required by EU ESPR and recognized by customs authorities.',
  },
];
---

<Marketing 
  title="Transparent Pricing — Industrial-Grade Digital Passports"
  description="Simple, transparent pricing for outdoor and activewear brands. EU data residency and GS1 compliance included as standard.">
  
  <!-- Header -->
  <section class="pt-32 pb-20 bg-void">
    <div class="container mx-auto px-6 max-w-[1200px]">
      <SectionLabel label="TRANSPARENT PRICING" class="mb-8" />
      <h1 class="font-display font-bold text-4xl lg:text-5xl text-white tracking-tight uppercase leading-[1.1] mb-6">
        Priced for mid-market brands.<br />
        Not for enterprise budgets.
      </h1>
      <p class="font-mono text-metal uppercase tracking-widest max-w-2xl leading-relaxed">
        All plans include EU data residency, GS1-compliant passports, and full data portability.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pb-32 bg-void">
    <div class="container mx-auto px-6 max-w-[1200px]">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        {plans.map((plan) => (
          <div class:list={[
            "relative flex flex-col bg-surface-1 border p-10 pt-12",
            plan.popular ? "border-signal" : "border-border-default"
          ]}>
            {plan.popular && (
              <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
                <Badge label="MOST POPULAR" color="signal" variant="solid" />
              </div>
            )}
            
            <div class="mb-8">
              <span class="font-mono text-[10px] text-metal uppercase tracking-[0.2em]">{plan.name}</span>
              <div class="mt-4 flex items-baseline gap-2">
                <span class="font-display font-bold text-4xl text-white">{plan.price}</span>
                <span class="font-mono text-metal text-sm">/MONTH</span>
              </div>
            </div>

            <div class="h-px bg-border-default w-full mb-8"></div>

            <div class="flex-1 space-y-4 mb-10">
              {plan.features.map((feature) => (
                <div class:list={["flex items-start gap-3", !feature.included && "opacity-40"]}>
                  {feature.included ? (
                    <CheckCircle size={16} class="text-verified mt-0.5 shrink-0" />
                  ) : (
                    <XCircle size={16} class="text-metal mt-0.5 shrink-0" />
                  )}
                  <span class:list={[
                    "font-mono text-xs uppercase tracking-wider leading-relaxed",
                    feature.included ? "text-white" : "text-metal line-through"
                  ]}>
                    {feature.label}
                  </span>
                </div>
              ))}
            </div>

            <Button variant={plan.variant} size="lg" class="w-full" href="#waitlist">
              {plan.cta}
            </Button>
          </div>
        ))}
      </div>

      <!-- Enterprise Row -->
      <div class="bg-surface-1 border border-border-default p-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <p class="font-mono text-sm text-metal uppercase tracking-widest">
          <span class="text-white font-bold">ENTERPRISE</span> — Custom pricing for brand groups and retailers.
        </p>
        <Button variant="ghost" href="/contact">
          CONTACT US <ArrowRight size={16} class="ml-2" />
        </Button>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-32 bg-surface-1 border-t border-border-default">
    <div class="container mx-auto px-6 max-w-[800px]">
      <div class="mb-16">
        <SectionLabel label="QUESTIONS & PROTOCOLS" class="mb-8" />
        <h2 class="font-display font-bold text-3xl text-white tracking-tight uppercase">Frequently Asked Questions</h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-void border border-border-default open:border-metal transition-all duration-200">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-display font-semibold text-white uppercase tracking-widest text-sm">
                {faq.q}
              </span>
              <span class="text-metal group-open:rotate-180 transition-transform duration-200">
                <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2"/>
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6">
              <p class="font-mono text-sm text-metal uppercase tracking-wider leading-relaxed">
                {faq.a}
              </p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</Marketing>
