---
import { Menu, X } from '@lucide/astro';

const navLinks = [
  { label: 'PRODUCT', href: '/product' },
  { label: 'PRICING', href: '/pricing' },
];
---

<!-- Announcement Strip -->
<div id="announcement-strip" class="announcement-strip">
  <div class="strip-content">
    <span class="blink-dot"></span>
    <span class="strip-text">EU ESPR TEXTILE ENFORCEMENT DEADLINE: 2028</span>
    <span class="strip-separator">·</span>
    <span class="strip-cta">IS YOUR BRAND COMPLIANT?</span>
  </div>
  <button id="strip-close" class="strip-close" aria-label="Dismiss announcement">
    ✕
  </button>
</div>

<header id="site-header" class="header-main">
  <div class="container-inner h-full flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="logo-wrapper">
      <img src="/brand-assets/passr-logo-optimized.webp" alt="Passr Logo" class="logo-img" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      <nav class="flex items-center gap-8">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </nav>

      <div class="nav-sep"></div>

      <div class="flex items-center gap-4">
        <a href="https://app.passr.eu" class="nav-link" target="_blank" rel="noopener">SIGN IN</a>
        <a href="/#waitlist" class="btn-get-started">GET STARTED</a>
      </div>
    </div>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="md:hidden text-[#585858] p-2" aria-label="Toggle menu">
      <Menu id="menu-icon" size={20} class="block" />
      <X id="close-icon" size={20} class="hidden" />
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-nav" class="hidden mobile-drawer">
    <nav class="flex flex-col">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
      <a href="https://app.passr.eu" class="mobile-link" target="_blank" rel="noopener">SIGN IN</a>
      <a href="/#waitlist" class="btn-get-started w-full mt-5 h-12 flex items-center justify-center">
        GET STARTED
      </a>
    </nav>
  </div>
</header>

<style>
  /* ── Announcement Strip ── */
  .announcement-strip {
    width: 100%;
    height: 36px;
    background: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed; /* FIXED top */
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000; /* Above everything */
    overflow: hidden;
  }

  .strip-content {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blink-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FF3B30;
    flex-shrink: 0;
    animation: blink 1.4s step-end infinite;
  }

  .strip-text { color: #858585; }
  .strip-separator { color: #333333; }
  .strip-cta { color: #FF3B30; cursor: pointer; }

  .strip-close {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: #444444;
    font-size: 12px;
    cursor: pointer;
    padding: 4px 8px;
    font-family: 'Roboto Mono', monospace;
    transition: color 100ms;
  }

  .strip-close:hover { color: #858585; }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Main Nav ── */
  .header-main {
    height: 64px;
    background: rgba(244, 244, 244, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #E0E0E0;
    position: fixed;
    top: 36px; /* Explicit offset by strip height */
    left: 0;
    right: 0;
    z-index: 900;
    transition: border-color 200ms ease, top 200ms ease, background 200ms ease;
  }

  .header-main.scrolled {
    border-bottom-color: #C8C8C8;
    background: rgba(255, 255, 255, 0.98);
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-img {
    height: 24px;
    width: auto;
    display: block;
  }

  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 13px;
    color: #585858;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 100ms ease;
  }

  .nav-link:hover { color: #0A0A0A; }

  .nav-sep {
    width: 1px;
    height: 16px;
    background: #E0E0E0;
  }

  .btn-get-started {
    background: #FF3B30;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 2px;
    text-decoration: none;
    transition: background 100ms ease;
    box-shadow: 0 1px 3px rgba(255, 59, 48, 0.3);
  }

  .btn-get-started:hover { background: #E0342A; }

  .mobile-drawer {
    position: fixed;
    top: 100px; /* 36 + 64 */
    left: 0;
    right: 0;
    background: #FFFFFF;
    border-bottom: 1px solid #E0E0E0;
    padding: 24px;
    z-index: 899;
    transition: top 200ms ease;
  }
</style>

<script>
  const strip = document.getElementById('announcement-strip');
  const closeBtn = document.getElementById('strip-close');
  const header = document.getElementById('site-header');
  const nav    = document.getElementById('mobile-nav');
  const toggle = document.getElementById('menu-toggle');
  const menuIcon  = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  function handleDismiss() {
    if (strip) strip.style.display = 'none';
    if (header) header.style.top = '0px';
    if (nav) nav.style.top = '64px';
    // Also adjust body padding to prevent large gap
    document.body.style.paddingTop = '64px';
  }

  // Check dismissal state
  if (sessionStorage.getItem('strip-dismissed') === 'true') {
    handleDismiss();
  }

  closeBtn?.addEventListener('click', () => {
    if (!strip || !header) return;
    strip.style.transition = 'height 200ms ease, opacity 200ms ease';
    strip.style.opacity = '0';
    strip.style.height = '0';
    setTimeout(() => {
      strip.style.display = 'none';
    }, 200);
    header.style.top = '0px';
    if (nav) nav.style.top = '64px';
    document.body.style.paddingTop = '64px';
    sessionStorage.setItem('strip-dismissed', 'true');
  });

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 80);
  });

  toggle?.addEventListener('click', () => {
    const hidden = nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden', !hidden);
    menuIcon?.classList.toggle('hidden', !hidden);
    closeIcon?.classList.toggle('hidden', hidden);
  });

  nav?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      nav.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });
</script>
