---
import { Menu, X } from '@lucide/astro';

const navLinks = [
  { label: 'PRODUCT', href: '/product' },
  { label: 'PRICING', href: '/pricing' },
];
---

<header id="site-header" class="header-main">
  <div class="container-inner h-full flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="logo-wrapper">
      <span class="logo-text">PASSR</span>
      <span class="logo-dot"></span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      <nav class="flex items-center gap-8">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </nav>

      <div class="nav-sep"></div>

      <div class="flex items-center gap-4">
        <a href="https://app.passr.eu" class="nav-link" target="_blank" rel="noopener">SIGN IN</a>
        <a href="/#waitlist" class="btn-get-started">GET STARTED</a>
      </div>
    </div>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="md:hidden text-[#858585] p-2" aria-label="Toggle menu">
      <Menu id="menu-icon" size={20} class="block" />
      <X id="close-icon" size={20} class="hidden" />
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-nav" class="hidden mobile-drawer">
    <nav class="flex flex-col">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
      <a href="https://app.passr.eu" class="mobile-link" target="_blank" rel="noopener">SIGN IN</a>
      <a href="/#waitlist" class="btn-get-started w-full mt-5 h-12 flex items-center justify-center">
        GET STARTED
      </a>
    </nav>
  </div>
</header>

<style>
  .header-main {
    height: 64px;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #1A1A1A;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: border-color 200ms ease;
  }

  .header-main.scrolled {
    border-bottom-color: #2A2A2A;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #F4F4F4;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .logo-dot {
    width: 7px;
    height: 7px;
    background: #FF3B30;
    border-radius: 50%;
    margin-left: 3px;
    margin-bottom: 8px;
  }

  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 13px;
    color: #858585;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 100ms ease;
  }

  .nav-link:hover { color: #F4F4F4; }

  .nav-sep {
    width: 1px;
    height: 16px;
    background: #2A2A2A;
  }

  .btn-get-started {
    background: #FF3B30;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 2px;
    text-decoration: none;
    transition: background 100ms ease;
  }

  .btn-get-started:hover { background: #E0342A; }

  .mobile-drawer {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    background: #111111;
    border-bottom: 1px solid #222222;
    padding: 24px;
    z-index: 99;
  }

  .mobile-link {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 16px;
    color: #858585;
    padding: 14px 0;
    border-bottom: 1px solid #1A1A1A;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 100ms ease;
  }

  .mobile-link:last-of-type { border-bottom: none; }
  .mobile-link:hover { color: #F4F4F4; }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const nav    = document.getElementById('mobile-nav');
  const menuIcon  = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 80);
  });

  toggle?.addEventListener('click', () => {
    const hidden = nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden', !hidden);
    menuIcon?.classList.toggle('hidden', !hidden);
    closeIcon?.classList.toggle('hidden', hidden);
  });

  nav?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      nav.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });
</script>
