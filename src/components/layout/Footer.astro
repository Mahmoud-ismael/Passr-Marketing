---
import Badge from '../shared/Badge.astro';

const currentYear = 2026;
---

<footer class="section-container bg-surface-1 border-t border-border-subtle pt-20 pb-12">
  <div class="container-inner">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-20">
      <!-- Col 1: Brand -->
      <div>
        <a href="/" class="relative inline-flex items-center group mb-6">
          <span class="font-display font-bold text-xl tracking-tighter text-white uppercase">PASSR</span>
          <div class="absolute -top-1 -right-2 w-1.5 h-1.5 bg-signal rounded-full"></div>
        </a>
        <p class="font-mono text-[11px] text-metal uppercase leading-relaxed tracking-[0.12em] max-w-[200px]">
          Digital Passport Infrastructure for global industrial supply chains.
        </p>
      </div>

      <!-- Col 2: Links -->
      <div class="grid grid-cols-2 gap-8">
        <nav class="flex flex-col gap-4">
          <a href="/product" class="font-mono text-[11px] text-metal hover:text-white transition-colors uppercase tracking-[0.12em]">Product</a>
          <a href="/pricing" class="font-mono text-[11px] text-metal hover:text-white transition-colors uppercase tracking-[0.12em]">Pricing</a>
          <a href="/docs" class="font-mono text-[11px] text-metal hover:text-white transition-colors uppercase tracking-[0.12em]">Docs</a>
        </nav>
        <nav class="flex flex-col gap-4">
          <a href="/legal/privacy" class="font-mono text-[11px] text-metal hover:text-white transition-colors uppercase tracking-[0.12em]">Privacy Policy</a>
          <a href="/legal/terms" class="font-mono text-[11px] text-metal hover:text-white transition-colors uppercase tracking-[0.12em]">Terms of Service</a>
          <a href="/legal/dpa" class="font-mono text-[11px] text-metal hover:text-white transition-colors uppercase tracking-[0.12em]">DPA</a>
        </nav>
      </div>

      <!-- Col 3: Compliance -->
      <div class="flex flex-col gap-6 items-start md:items-end">
        <div class="flex flex-col items-start md:items-end gap-2">
          <span class="font-mono text-[11px] text-metal uppercase tracking-[0.12em] mb-1">Compliance Status</span>
          <Badge label="● SYSTEMS OPERATIONAL" color="verified" variant="outline" />
          <div class="font-mono text-[11px] text-metal uppercase tracking-[0.12em] mt-2 flex items-center gap-2">
            <span>EU GDPR COMPLIANT</span>
            <div class="w-1 h-1 bg-metal rounded-full"></div>
            <span>ISO 27001</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-border-subtle flex justify-between items-center">
      <p class="font-mono text-[11px] text-metal uppercase tracking-[0.12em]">
        © {currentYear} Passr. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="https://twitter.com/passr" class="text-metal hover:text-white transition-colors font-mono text-[11px] uppercase tracking-[0.12em]">X / Twitter</a>
        <a href="https://linkedin.com/company/passr" class="text-metal hover:text-white transition-colors font-mono text-[11px] uppercase tracking-[0.12em]">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
