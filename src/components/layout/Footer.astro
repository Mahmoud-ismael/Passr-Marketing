<footer class="site-footer">
  <div class="container-inner">

    <!-- Row 1: 3 columns -->
    <div class="footer-top">

      <!-- Col 1: Wordmark + tagline -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/brand-assets/passr-logo-optimized.webp" alt="Passr Logo" class="footer-logo-img" />
        </a>
        <p class="footer-tagline">
          Digital Product Passport Infrastructure
        </p>
      </div>

      <!-- Col 2: Links -->
      <nav class="footer-links">
        <a href="/product"       class="footer-link">Product</a>
        <a href="/pricing"       class="footer-link">Pricing</a>
        <a href="/legal/privacy" class="footer-link">Privacy</a>
        <a href="/legal/terms"   class="footer-link">Terms</a>
        <a href="/legal/dpa"     class="footer-link">DPA</a>
      </nav>

      <!-- Col 3: Status + badges -->
      <div class="footer-status">
        <div class="status-operational">
          <span class="status-dot"></span>ALL SYSTEMS OPERATIONAL
        </div>
        <div class="status-badge">EU GDPR COMPLIANT</div>
        <div class="status-badge">GS1 DIGITAL LINK CERTIFIED</div>
      </div>

    </div>

    <!-- Row 2: Bottom bar -->
    <div class="footer-bottom">
      <span class="footer-copy">
        © 2026 Passr — Hisako Technologies OÜ, Estonia
      </span>
      <a href="mailto:hello@passr.eu" class="footer-email">hello@passr.eu</a>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: #FFFFFF;
    border-top: 1px solid #E0E0E0;
    padding: 48px 0;
  }

  /* Row 1 */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    align-items: start;
    padding-bottom: 32px;
  }

  /* Brand */
  .footer-brand { display: flex; flex-direction: column; gap: 10px; }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .footer-logo-img {
    height: 18px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #585858;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.5;
  }

  /* Links */
  .footer-links {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 16px 24px;
    align-content: flex-start;
  }

  .footer-link {
    font-family: 'Roboto Mono', monospace;
    font-size: 12px;
    color: #585858;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 100ms ease;
  }

  .footer-link:hover { color: #0A0A0A; }

  /* Status */
  .footer-status {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }

  .status-operational {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #22C55E;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .status-dot {
    width: 5px;
    height: 5px;
    background: #22C55E;
    border-radius: 50%;
    display: inline-block;
  }

  .status-badge {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #909090;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Row 2 */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #F4F4F4;
    padding-top: 24px;
  }

  .footer-copy,
  .footer-email {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #909090;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .footer-email:hover { color: #585858; }

  /* Mobile */
  @media (max-width: 767px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-links {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 12px 20px;
    }

    .footer-status { align-items: flex-start; }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
