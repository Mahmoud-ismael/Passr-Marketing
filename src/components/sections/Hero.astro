---
import { ChevronDown } from '@lucide/astro';
---

<section class="hero-section">
  <!-- Background Grid -->
  <div class="hero-background"></div>

  <!-- Announcement Strip -->
  <div class="announcement-strip">
    <div class="flex items-center gap-3">
      <div class="announcement-dot"></div>
      <span class="announcement-text">EU ESPR TEXTILE ENFORCEMENT DEADLINE: 2028</span>
    </div>
    <span class="announcement-separator">·</span>
    <span class="announcement-cta">IS YOUR BRAND COMPLIANT?</span>
  </div>

  <!-- Main Content -->
  <div class="hero-content">
    <!-- Eyebrow -->
    <div class="hero-eyebrow">
      DIGITAL PRODUCT PASSPORT INFRASTRUCTURE
    </div>

    <!-- Headline -->
    <div class="hero-headline">
      <div class="headline-line" style="animation-delay: 0s;">THE COMPLIANCE</div>
      <div class="headline-line" style="animation-delay: 0.1s;">STANDARD FOR</div>
      <div class="headline-line" style="animation-delay: 0.2s;">
        OUTDOOR <span class="text-signal">BRANDS.</span>
      </div>
    </div>

    <!-- Subheadline -->
    <p class="hero-subheadline">
      GS1-compliant digital product passports for EU ESPR, AGEC,
      and PFAS regulations. Built for mid-market outdoor brands.
      Live in days, not months.
    </p>

    <!-- CTA Row -->
    <div class="hero-cta-row">
      <a href="#waitlist" class="btn-primary">
        REQUEST EARLY ACCESS
      </a>
      <a href="#ecosystem" class="btn-secondary">
        SEE HOW IT WORKS →
      </a>
    </div>

    <!-- Trust Signals -->
    <div class="hero-trust-signals">
      <div class="trust-signal">
        <span class="trust-dot"></span> GS1 DIGITAL LINK COMPLIANT
      </div>
      <div class="trust-signal">
        <span class="trust-dot"></span> EU DATA RESIDENCY
      </div>
      <div class="trust-signal">
        <span class="trust-dot"></span> ESPR READY
      </div>
      <div class="trust-signal">
        <span class="trust-dot"></span> GDPR COMPLIANT
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <span class="scroll-text">SCROLL TO EXPLORE</span>
    <ChevronDown size={20} class="scroll-icon" />
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    background: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 24px;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    z-index: 0;
  }

  /* Announcement Strip */
  .announcement-strip {
    position: absolute;
    top: 64px; /* Assuming 64px nav height */
    left: 0;
    right: 0;
    height: 36px;
    background: #0D0D0D;
    border-bottom: 1px solid #1A1A1A;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    z-index: 10;
  }

  .announcement-dot {
    width: 6px;
    height: 6px;
    background: #FF3B30;
    border-radius: 50%;
    animation: blink 1.4s step-end infinite;
  }

  .announcement-text {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #585858;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .announcement-separator {
    color: #2A2A2A;
  }

  .announcement-cta {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #FF3B30;
    text-transform: uppercase;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Main Content */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    width: 100%;
    text-align: center;
    padding-top: 40px; /* Offset for announcement strip */
  }

  .hero-eyebrow {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #585858;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-left: 1px solid #585858;
    padding-left: 12px;
    margin: 0 auto 32px auto;
    display: table; /* Centers the block with border-left */
  }

  .hero-headline {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .headline-line {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(52px, 7.5vw, 96px);
    line-height: 0.93;
    letter-spacing: -0.03em;
    color: #F4F4F4;
    text-transform: uppercase;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }

  .text-signal {
    color: #FF3B30;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-subheadline {
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    color: #585858;
    line-height: 1.8;
    max-width: 560px;
    margin: 40px auto 0 auto;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .hero-cta-row {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #FF3B30;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 16px 36px;
    border-radius: 2px;
    text-decoration: none;
    transition: background 100ms ease;
  }

  .btn-primary:hover {
    background: #E0342A;
  }

  .btn-secondary {
    background: transparent;
    color: #585858;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 16px 24px;
    border: 1px solid #2A2A2A;
    border-radius: 2px;
    text-decoration: none;
    transition: all 100ms ease;
  }

  .btn-secondary:hover {
    color: #F4F4F4;
    border-color: #585858;
  }

  .hero-trust-signals {
    margin-top: 24px;
    display: flex;
    gap: 32px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .trust-signal {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #383838;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .trust-dot {
    width: 5px;
    height: 5px;
    background: #22C55E;
    border-radius: 50%;
    display: inline-block;
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 10;
  }

  .scroll-text {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #2A2A2A;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .scroll-icon {
    color: #2A2A2A;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Mobile Overrides */
  @media (max-width: 767px) {
    .hero-headline {
      font-size: clamp(40px, 10vw, 60px);
    }
    .headline-line {
      font-size: inherit;
    }
    .hero-subheadline {
      font-size: 13px;
    }
    .hero-cta-row {
      flex-direction: column;
      width: 100%;
    }
    .btn-primary, .btn-secondary {
      width: 100%;
      text-align: center;
    }
    .hero-trust-signals {
      gap: 16px;
      justify-content: flex-start;
    }
    .trust-signal {
      width: calc(50% - 16px);
    }
  }
</style>
