---
import { ChevronDown } from '@lucide/astro';
---

<section class="hero-section">
  <!-- Background Grid -->
  <div class="hero-background"></div>

  <!-- Main Content -->
  <div class="hero-content">
    <!-- Eyebrow -->
    <div class="hero-eyebrow">
      DIGITAL PRODUCT PASSPORT INFRASTRUCTURE
    </div>

    <!-- Headline -->
    <div class="hero-headline">
      <div class="headline-line" style="animation-delay: 0s;">THE COMPLIANCE</div>
      <div class="headline-line" style="animation-delay: 0.1s;">STANDARD FOR</div>
      <div class="headline-line" style="animation-delay: 0.2s;">
        OUTDOOR <span class="text-signal">BRANDS.</span>
      </div>
    </div>

    <!-- Subheadline -->
    <p class="hero-subheadline">
      GS1-compliant digital product passports for EU ESPR, AGEC,
      and PFAS regulations. Built for mid-market outdoor brands.
      Live in days, not months.
    </p>

    <!-- CTA Row -->
    <div class="hero-cta-row">
      <a href="#waitlist" class="btn-primary">
        REQUEST EARLY ACCESS
      </a>
      <a href="#ecosystem" class="btn-secondary">
        SEE HOW IT WORKS →
      </a>
    </div>

    <!-- Trust Signals -->
    <div class="hero-trust-signals">
      <div class="trust-signal">
        <span class="trust-dot"></span> GS1 DIGITAL LINK COMPLIANT
      </div>
      <div class="trust-signal">
        <span class="trust-dot"></span> EU DATA RESIDENCY
      </div>
      <div class="trust-signal">
        <span class="trust-dot"></span> ESPR READY
      </div>
      <div class="trust-signal">
        <span class="trust-dot"></span> GDPR COMPLIANT
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <span class="scroll-text">SCROLL TO EXPLORE</span>
    <ChevronDown size={20} class="scroll-icon" />
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    background: #F4F4F4;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 120px 24px 80px 24px; /* top = fixed header (80px) + 40px breathing room */
  }

  /* Dark grid lines on light background */
  .hero-background {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    z-index: 0;
  }

  /* Main Content */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    width: 100%;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #909090;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-left: 1px solid #909090;
    padding-left: 12px;
    margin: 0 auto 32px auto;
    display: table;
  }

  .hero-headline {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .headline-line {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(52px, 7.5vw, 96px);
    line-height: 0.93;
    letter-spacing: -0.03em;
    color: #0A0A0A;
    text-transform: uppercase;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }

  .text-signal { color: #FF3B30; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-subheadline {
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    color: #585858;
    line-height: 1.8;
    max-width: 560px;
    margin: 40px auto 0 auto;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .hero-cta-row {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #FF3B30;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 16px 36px;
    border-radius: 2px;
    text-decoration: none;
    box-shadow: 0 1px 3px rgba(255,59,48,0.3);
    transition: background 100ms ease;
  }

  .btn-primary:hover { background: #E0342A; }

  .btn-secondary {
    background: transparent;
    color: #585858;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 16px 24px;
    border: 1px solid #C8C8C8;
    border-radius: 2px;
    text-decoration: none;
    transition: all 100ms ease;
  }

  .btn-secondary:hover {
    color: #0A0A0A;
    border-color: #585858;
  }

  .hero-trust-signals {
    margin-top: 24px;
    display: flex;
    gap: 32px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .trust-signal {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #909090;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .trust-dot {
    width: 5px;
    height: 5px;
    background: #22C55E;
    border-radius: 50%;
    display: inline-block;
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 10;
  }

  .scroll-text {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #C8C8C8;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .scroll-icon {
    color: #C8C8C8;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .hero-section { padding-top: 100px; }
    .headline-line { font-size: clamp(40px, 10vw, 60px); }
    .hero-subheadline { font-size: 13px; }
    .hero-cta-row { flex-direction: column; width: 100%; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; }
    .hero-trust-signals { gap: 16px; justify-content: flex-start; }
    .trust-signal { width: calc(50% - 16px); }
  }
</style>
