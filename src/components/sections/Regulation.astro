---
import SectionLabel from '../shared/SectionLabel.astro';
import { AlertTriangle } from '@lucide/astro';

const timeline = [
  {
    date: 'July 2024',
    status: 'verified',
    label: 'ESPR REGULATION ENTERED INTO FORCE',
    body: 'EU 2024/1781. Digital Product Passports are now EU law, not proposal.',
  },
  {
    date: 'January 2025',
    status: 'verified',
    label: 'TEXTILE DELEGATED ACT FINALIZED',
    body: 'Data requirements confirmed. No further regulatory uncertainty. Implementation should have started.',
  },
  {
    date: 'January 2026',
    status: 'verified',
    label: 'BATTERY DPP ENFORCEMENT LIVE',
    body: 'Proof the enforcement mechanism works. Market surveillance actively checking at EU borders.',
  },
  {
    date: 'September 2026',
    status: 'warning',
    label: 'GREEN CLAIMS DIRECTIVE TAKES EFFECT',
    body: 'Unverified sustainability claims banned. DPP data becomes legal defence against greenwashing enforcement.',
  },
  {
    date: 'Late 2026 / Q1 2027',
    status: 'warning',
    label: 'TEXTILE DELEGATED ACT ADOPTION',
    body: 'The 18-month implementation clock starts here. Brands that are not ready will scramble.',
  },
  {
    date: 'Mid 2028',
    status: 'danger',
    label: 'MANDATORY DPP ENFORCEMENT — TEXTILES',
    body: 'Every outdoor brand selling in the EU requires a compliant Digital Product Passport. Non-compliant products blocked at import.',
  },
];
---

<section class="section-container bg-[#0A0A0A]">
  <div class="container-inner">
    <div class="mb-16">
      <SectionLabel label="EU REGULATORY TIMELINE" class="mb-8" />
      <h2 class="font-display font-bold text-[clamp(36px,4vw,56px)] text-[#F4F4F4] tracking-[-0.02em] uppercase leading-[1.0]">
        The deadline is confirmed.<br />
        No extensions have been granted.
      </h2>
    </div>

    <!-- Timeline Wrapper -->
    <div class="relative">
      <!-- Vertical Line -->
      <div class="timeline-line"></div>

      <div class="flex flex-col">
        {timeline.map((item, index) => {
          const isLast = index === timeline.length - 1;
          const isWarning = item.status === 'warning';
          const isDanger = item.status === 'danger';
          
          return (
            <div class="timeline-entry">
              <!-- Dot Column -->
              <div class="w-6 flex flex-col items-center flex-shrink-0">
                <div class:list={[
                  "timeline-dot",
                  item.status === 'verified' && "dot-verified",
                  isWarning && "dot-warning",
                  isDanger && "dot-danger"
                ]}></div>
              </div>

              <!-- Content Column -->
              <div class="flex flex-col">
                <span class="font-mono text-[11px] text-[#858585] uppercase tracking-[0.12em] mb-1">
                  {item.date}
                </span>
                <h3 class:list={[
                  "font-display uppercase tracking-[0.02em] mb-2",
                  isDanger ? "text-[20px] font-bold text-[#FF3B30]" : "text-[16px] font-semibold text-[#F4F4F4]"
                ]}>
                  {item.label}
                </h3>
                <p class="font-mono text-[13px] text-[#858585] leading-[1.6] max-w-2xl">
                  {item.body}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Callout Card -->
    <div class="callout-card">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="flex items-start gap-6">
          <AlertTriangle size={20} class="text-[#FF3B30] shrink-0 mt-1" />
          <p class="font-display font-semibold text-[15px] text-[#F4F4F4] leading-relaxed max-w-2xl">
            Brands piloting now will have a validated system before enforcement. <br class="hidden lg:block" />
            Brands waiting will scramble during the same 18-month window as every competitor.
          </p>
        </div>
        <a href="/get-started" class="btn-pilot shrink-0">
          START YOUR PILOT →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-line {
    position: absolute;
    left: 11px;
    width: 1px;
    background: #2A2A2A;
    top: 24px;
    bottom: 48px;
    z-index: 0;
  }

  .timeline-entry {
    display: flex;
    gap: 32px;
    padding-bottom: 48px;
    position: relative;
    z-index: 1;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .dot-verified {
    background: #22C55E;
    border: 1px solid #22C55E;
  }

  .dot-warning {
    background: transparent;
    border: 1px solid #F59E0B;
    animation: pulse-warning 2s ease infinite;
  }

  .dot-danger {
    width: 16px;
    height: 16px;
    background: #FF3B30;
    border: 1px solid #FF3B30;
    margin-top: 4px;
    margin-left: -3px; /* Center larger dot */
    animation: pulse-danger 2s ease infinite;
  }

  @keyframes pulse-warning {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(245, 158, 11, 0); }
  }

  @keyframes pulse-danger {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(255, 59, 48, 0); }
  }

  .callout-card {
    background: #111111;
    border: 1px solid #333333;
    border-left: 4px solid #FF3B30;
    padding: 28px 32px;
    margin-top: 40px;
  }

  .btn-pilot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #FF3B30;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: 2px;
    border: none;
    min-width: 200px;
    transition: background 200ms ease;
    text-decoration: none;
  }

  .btn-pilot:hover {
    background: #E0342A;
  }

  @media (max-width: 768px) {
    .callout-card .flex {
      flex-direction: column;
      align-items: flex-start;
    }
    .btn-pilot {
      width: 100%;
    }
  }
</style>
