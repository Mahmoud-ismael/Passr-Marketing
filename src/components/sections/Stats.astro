---
const stats = [
  {
    value: '2027',
    label: 'EU ENFORCEMENT DEADLINE',
  },
  {
    value: '€500K',
    label: 'MAXIMUM GDPR FINE',
  },
  {
    value: '18 MONTHS',
    label: 'IMPLEMENTATION WINDOW',
  },
  {
    value: '0 GRACE',
    label: 'EXTENSIONS GRANTED',
  },
];
---

<section class="section-container bg-surface-1 border-y border-border-subtle">
  <div class="container-inner">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      {stats.map((stat) => (
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
          <span class="font-display font-bold text-[var(--text-stats)] text-white tracking-[-0.02em] uppercase leading-[1.0]">
            {stat.value}
          </span>
          <span class="font-mono text-[11px] text-metal uppercase tracking-[0.12em] mt-3">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
