---
import SectionLabel from '../shared/SectionLabel.astro';
import { Upload, Shield, QrCode, CheckCircle } from '@lucide/astro';

const steps = [
  {
    num: '01',
    icon: Upload,
    iconColor: 'text-signal',
    title: 'IMPORT YOUR CATALOG',
    body: 'Drop a CSV from Shopify or your ERP. Bulk import 500 SKUs in seconds.',
    time: '~5 MIN',
  },
  {
    num: '02',
    icon: Shield,
    iconColor: 'text-metal',
    title: 'COMPLETE COMPLIANCE DATA',
    body: 'Fill the Compliance Locker: PFAS reports, material composition, factory origins.',
    time: '~15 MIN',
  },
  {
    num: '03',
    icon: QrCode,
    iconColor: 'text-metal',
    title: 'GENERATE GS1 PASSPORTS',
    body: 'Download print-ready QR codes. Hand to packaging designer. Print on hangtags.',
    time: '~2 MIN',
  },
  {
    num: '04',
    icon: CheckCircle,
    iconColor: 'text-verified',
    title: 'STAY AHEAD OF DEADLINES',
    body: 'Automated alerts for expiring certs. Dashboard tracks compliance across every SKU.',
    time: 'ONGOING',
  },
];
---

<section class="section-container bg-void">
  <div class="container-inner">
    <div class="mb-[var(--space-headline-body)] text-center">
      <SectionLabel label="HOW IT WORKS" class="justify-center border-l-0 border-b border-metal inline-block pb-2 px-6 mb-[var(--space-label-headline)]" />
      <h2 class="font-display font-bold text-[var(--text-h2)] text-white tracking-[-0.02em] uppercase leading-[1.0]">
        Live in under 30 minutes.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step) => (
        <div class="card-featured relative flex flex-col items-center md:items-start text-center md:text-left">
          <!-- Watermark Number -->
          <div class="absolute top-4 right-4 font-display font-bold text-4xl text-surface-3 opacity-30 pointer-events-none">
            {step.num}
          </div>

          <!-- Icon Circle -->
          <div class="w-12 h-12 rounded-none bg-surface-1 border border-border-default flex items-center justify-center mb-6">
            <step.icon size={24} class={step.iconColor} />
          </div>

          <h3 class="font-display font-semibold text-white uppercase tracking-[0.12em] text-[var(--text-card-title)] mb-4">
            {step.title}
          </h3>
          <p class="font-mono text-[13px] text-metal uppercase tracking-[0.12em] leading-relaxed">
            {step.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Time Estimate Row -->
    <div class="mt-16 pt-8 border-t border-border-subtle flex justify-center">
      <div class="font-mono text-[11px] text-metal uppercase tracking-[0.12em] flex flex-wrap justify-center gap-x-6 gap-y-2">
        {steps.map((step, index) => (
          <div class="flex items-center gap-2">
            <span>STEP {step.num}: {step.time}</span>
            {index !== steps.length - 1 && <span class="hidden md:inline opacity-30">·</span>}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
