---
import SectionLabel from '../shared/SectionLabel.astro';
import { Upload, Shield, QrCode, CheckCircle } from '@lucide/astro';

const steps = [
  {
    num: '01',
    icon: Upload,
    iconColor: 'text-signal',
    title: 'IMPORT YOUR CATALOG',
    body: 'Drop a CSV from Shopify or your ERP. Bulk import 500 SKUs in seconds.',
    time: '~5 MIN',
  },
  {
    num: '02',
    icon: Shield,
    iconColor: 'text-metal',
    title: 'COMPLETE COMPLIANCE DATA',
    body: 'Fill the Compliance Locker: PFAS reports, material composition, factory origins.',
    time: '~15 MIN',
  },
  {
    num: '03',
    icon: QrCode,
    iconColor: 'text-metal',
    title: 'GENERATE GS1 PASSPORTS',
    body: 'Download print-ready QR codes. Hand to packaging designer. Print on hangtags.',
    time: '~2 MIN',
  },
  {
    num: '04',
    icon: CheckCircle,
    iconColor: 'text-verified',
    title: 'STAY AHEAD OF DEADLINES',
    body: 'Automated alerts for expiring certs. Dashboard tracks compliance across every SKU.',
    time: 'ONGOING',
  },
];
---

<section class="bg-surface-1 py-[120px]">
  <div class="container mx-auto px-6 max-w-[1200px]">
    <div class="mb-20 text-center">
      <SectionLabel label="HOW IT WORKS" class="justify-center border-l-0 border-b border-metal inline-block pb-2 px-6" />
      <h2 class="font-display font-bold text-4xl text-white tracking-tight uppercase mt-8">
        Live in under 30 minutes.
      </h2>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-16">
      <!-- Connection Line (Desktop) -->
      <div class="hidden md:block absolute top-[52px] left-0 w-full h-px border-t border-dashed border-border-strong -z-0"></div>

      {steps.map((step, index) => (
        <div class="relative flex flex-col items-center md:items-start text-center md:text-left z-10">
          <!-- Watermark Number -->
          <div class="absolute -top-4 md:-top-6 left-1/2 md:left-0 -translate-x-1/2 md:translate-x-0 font-display font-bold text-6xl text-surface-3 opacity-50 pointer-events-none -z-10">
            {step.num}
          </div>

          <!-- Icon Circle -->
          <div class="w-12 h-12 rounded-full bg-surface-1 border border-border-strong flex items-center justify-center mb-8">
            <step.icon size={24} class={step.iconColor} />
          </div>

          <h3 class="font-display font-semibold text-white uppercase tracking-widest text-sm mb-4">
            {step.title}
          </h3>
          <p class="font-mono text-xs text-metal uppercase tracking-wider leading-relaxed">
            {step.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Time Estimate Row -->
    <div class="mt-20 pt-8 border-t border-border-default flex justify-center">
      <div class="font-mono text-[10px] text-metal uppercase tracking-[0.2em] flex flex-wrap justify-center gap-x-6 gap-y-2">
        {steps.map((step, index) => (
          <div class="flex items-center gap-2">
            <span>STEP {step.num}: {step.time}</span>
            {index !== steps.length - 1 && <span class="hidden md:inline opacity-30">·</span>}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
