---
import SectionLabel from '../shared/SectionLabel.astro';
---

<section id="waitlist" class="section-container bg-surface-1 border-t-4 border-signal">
  <div class="container-inner max-w-[800px] text-center">
    <SectionLabel label="EARLY ACCESS" class="justify-center border-l-0 border-b border-metal inline-block pb-2 px-6 mb-[var(--space-label-headline)]" />
    
    <h2 class="font-display font-bold text-[var(--text-h2)] text-white tracking-[-0.02em] uppercase leading-[1.0] mb-[var(--space-headline-body)]">
      The 2028 deadline is fixed.<br />
      Your preparation window is not.
    </h2>

    <p class="font-mono text-[var(--text-body)] text-metal uppercase tracking-[0.12em] mb-[var(--space-body-cta)]">
      Join outdoor brands already building their DPP infrastructure.<br class="hidden md:block" />
      Setup takes under 30 minutes.
    </p>

    <div id="cta-form-container">
      <form id="waitlist-form" class="flex flex-col md:flex-row gap-0">
        <input 
          type="email" 
          name="email"
          required 
          placeholder="brand@yourcompany.com" 
          class="flex-1 h-14 bg-surface-3 border border-border-subtle px-6 font-mono text-[14px] text-white placeholder:text-metal focus:outline-none focus:border-metal transition-colors"
        />
        <button 
          type="submit" 
          class="h-14 bg-signal text-white font-display font-semibold uppercase tracking-[0.12em] px-10 hover:bg-[#E0342A] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          REQUEST ACCESS
        </button>
      </form>
      <p id="form-message" class="mt-6 font-mono text-[11px] uppercase tracking-[0.12em] min-h-[16px]"></p>
    </div>

    <div class="mt-12 flex flex-wrap justify-center gap-x-6 gap-y-2 opacity-50">
      <div class="font-mono text-[11px] text-metal uppercase tracking-[0.12em]">No credit card required</div>
      <div class="hidden md:block text-metal opacity-30">·</div>
      <div class="font-mono text-[11px] text-metal uppercase tracking-[0.12em]">EU data residency</div>
      <div class="hidden md:block text-metal opacity-30">·</div>
      <div class="font-mono text-[11px] text-metal uppercase tracking-[0.12em]">Cancel anytime</div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const message = document.getElementById('form-message');
  const button = form?.querySelector('button');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!button || !message) return;

    const formData = new FormData(form);
    const email = formData.get('email');

    button.disabled = true;
    message.textContent = 'TRANSMITTING...';
    message.className = 'mt-4 font-mono text-xs uppercase tracking-widest text-metal';

    try {
      const response = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      let result;
      const text = await response.text();
      try {
        result = JSON.parse(text);
      } catch (e) {
        result = { error: text || 'SERVER ERROR: NO DATA' };
      }

      if (response.ok) {
        const container = document.getElementById('cta-form-container');
        if (container) {
          container.innerHTML = `
            <div class="py-4 font-mono text-sm text-verified uppercase tracking-[0.2em] border border-verified/30 bg-verified/5">
              ACCESS REQUESTED — WE'LL BE IN TOUCH.
            </div>
          `;
        }
      } else {
        message.textContent = `ERROR: ${result.error || 'FAILED TO JOIN'}`;
        message.className = 'mt-4 font-mono text-xs uppercase tracking-widest text-signal';
        button.disabled = false;
      }
    } catch (error: any) {
      console.error('Waitlist Fetch Error:', error);
      message.textContent = `ERROR: ${error.name || 'FETCH ERROR'} - ${error.message || 'CONNECTION FAILED'}`;
      message.className = 'mt-4 font-mono text-xs uppercase tracking-widest text-signal';
      button.disabled = false;
    }
  });
</script>
