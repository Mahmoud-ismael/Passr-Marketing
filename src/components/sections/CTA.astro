---
---

<section id="waitlist" class="section-container bg-[#111111] border-t-2 border-[#FF3B30] py-[140px]">
  <div class="container-inner max-w-[720px] text-center">
    <!-- Eyebrow -->
    <div class="mb-6">
      <span class="font-mono text-[11px] text-[#FF3B30] uppercase tracking-[0.12em]">
        EARLY ACCESS PROGRAM
      </span>
    </div>
    
    <!-- Headline -->
    <h2 class="font-display font-bold text-[clamp(36px,5vw,64px)] text-[#F4F4F4] tracking-[-0.02em] uppercase leading-[1.0]">
      THE 2028 DEADLINE IS FIXED.<br />
      YOUR PREPARATION WINDOW <span class="text-[#FF3B30]">IS NOT.</span>
    </h2>

    <!-- Subtext -->
    <p class="font-mono text-[14px] text-[#858585] uppercase tracking-[0.12em] mt-6 max-w-[560px] mx-auto leading-relaxed">
      Join outdoor brands already building their DPP infrastructure.
      Setup takes under 30 minutes. No credit card required.
    </p>

    <!-- Form Container -->
    <div id="cta-form-container" class="mt-12">
      <form id="waitlist-form" class="flex flex-col md:flex-row gap-0 max-w-[520px] mx-auto">
        <input 
          type="email" 
          name="email"
          required 
          placeholder="brand@yourcompany.com" 
          class="cta-input"
        />
        <button type="submit" class="cta-button">
          REQUEST ACCESS
        </button>
      </form>
      <p id="form-message" class="mt-6 font-mono text-[11px] uppercase tracking-[0.12em] min-h-[16px]"></p>
    </div>

    <!-- Trust Line -->
    <div class="mt-5">
      <p class="font-mono text-[11px] text-[#585858] uppercase tracking-[0.12em]">
        EU DATA RESIDENCY <span class="text-[#333333] mx-2">·</span> 
        CANCEL ANYTIME <span class="text-[#333333] mx-2">·</span> 
        FULL DATA EXPORT ON CANCEL
      </p>
    </div>
  </div>
</section>

<style>
  .cta-input {
    flex: 1;
    background: #0A0A0A;
    border: 1px solid #333333;
    border-right: none;
    color: #F4F4F4;
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    padding: 0 20px;
    height: 52px;
    border-radius: 0;
    outline: none;
    transition: border-color 150ms ease;
  }

  .cta-input:focus {
    border-color: #858585;
  }

  .cta-input::placeholder {
    color: #333333;
  }

  .cta-button {
    background: #FF3B30;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0 32px;
    height: 52px;
    border: none;
    border-radius: 0;
    cursor: pointer;
    white-space: nowrap;
    transition: background 100ms ease;
  }

  .cta-button:hover {
    background: #E0342A;
  }

  @media (max-width: 767px) {
    .cta-input {
      border-right: 1px solid #333333;
      border-bottom: none;
      width: 100%;
    }
    .cta-button {
      width: 100%;
    }
  }
</style>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const message = document.getElementById('form-message');
  const button = form?.querySelector('button');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!button || !message) return;

    const formData = new FormData(form);
    const email = formData.get('email') as string;

    button.disabled = true;
    message.textContent = 'TRANSMITTING...';
    message.className = 'mt-4 font-mono text-[11px] uppercase tracking-[0.12em] text-[#858585]';

    try {
      const response = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (response.ok) {
        const container = document.getElementById('cta-form-container');
        if (container) {
          container.innerHTML = `
            <div class="bg-[#0A0A0A] border border-[#22C55E] p-8 max-w-[520px] mx-auto text-left">
              <div class="flex items-center gap-3 mb-4">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <span class="font-display font-semibold text-[14px] text-[#22C55E] uppercase tracking-[0.12em]">
                  ACCESS REQUESTED
                </span>
              </div>
              <p class="font-mono text-[13px] text-[#858585] leading-relaxed uppercase tracking-[0.04em]">
                We'll be in touch when your early access slot is ready. 
                You'll receive a confirmation at ${email}.
              </p>
            </div>
          `;
        }
      } else {
        const result = await response.json().catch(() => ({ error: 'SERVER ERROR' }));
        message.textContent = `ERROR: ${result.error || 'FAILED TO JOIN'}`;
        message.className = 'mt-4 font-mono text-[11px] uppercase tracking-[0.12em] text-[#FF3B30]';
        button.disabled = false;
      }
    } catch (error: any) {
      message.textContent = `ERROR: CONNECTION FAILED`;
      message.className = 'mt-4 font-mono text-[11px] uppercase tracking-[0.12em] text-[#FF3B30]';
      button.disabled = false;
    }
  });
</script>
