---
import SectionLabel from '../shared/SectionLabel.astro';
import { 
  FlaskConical, 
  QrCode, 
  Layers, 
  MapPin, 
  ShieldCheck, 
  Archive 
} from '@lucide/astro';

const features = [
  {
    icon: FlaskConical,
    title: 'PFAS COMPLIANCE ENGINE',
    body: 'Structured chemical safety data with lab report storage. PFAS toggle logic with Severe Wet Weather exemption support. Expiry tracking with automated alerts.',
  },
  {
    icon: QrCode,
    title: 'GS1 DIGITAL LINK GENERATOR',
    body: 'Generates compliant GS1 Digital Link URLs (https://verify.passr.eu/01/{GTIN}). Batch export ZIP of SVG/PNG files ready for packaging designers.',
  },
  {
    icon: Layers,
    title: 'MATERIAL COMPOSITION TREE',
    body: 'Structured input for fibre type, percentage, and origin. Validates total to 100%. Displayed on consumer-facing passport automatically.',
  },
  {
    icon: MapPin,
    title: 'SUPPLY CHAIN ORIGIN MAPPER',
    body: 'Document fabric mill, assembly factory, and warehouse locations. Satisfies EU ESPR origin traceability requirements.',
  },
  {
    icon: ShieldCheck,
    title: 'WHITE-LABEL PUBLIC PASSPORT',
    body: 'Consumer-facing passport shows your brand logo. Passr branding is footer-only. GS1 QR code links to live, updatable data.',
  },
  {
    icon: Archive,
    title: 'LEGAL DATA ESCROW',
    body: 'One-click bulk download of all certificates and compliance records. Your data leaves with you if you cancel. No lock-in.',
  },
];
---

<section class="section-container bg-void border-y border-border-subtle">
  <div class="container-inner">
    <div class="mb-[var(--space-headline-body)]">
      <SectionLabel label="PLATFORM FEATURES" class="mb-[var(--space-label-headline)]" />
      <h2 class="font-display font-bold text-[var(--text-h2)] text-white tracking-[-0.02em] uppercase leading-[1.0]">
        Built for outdoor brands.<br />
        Built to the GS1 standard.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="card-featured flex flex-col items-start">
          <feature.icon size={20} class="text-metal" />
          <h3 class="font-display font-semibold text-[var(--text-card-title)] text-white mt-4 mb-3 uppercase tracking-[0.12em]">
            {feature.title}
          </h3>
          <p class="font-mono text-[14px] text-metal leading-relaxed uppercase tracking-[0.12em]">
            {feature.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
