---
import { Shirt, ShieldCheck, Factory, Wrench, Smartphone, Check } from '@lucide/astro';

const nodes = [
  {
    id: 'brands',
    icon: Shirt,
    name: 'BRANDS',
    description: 'Manage product lines, oversee compliance, generate QR codes.',
    subdomain: 'app.passr.eu',
    tag: 'PAYING CLIENT',
    pos: { top: '0px', left: '50%', transform: 'translateX(-50%)' },
    width: '220px',
  },
  {
    id: 'regulators',
    icon: ShieldCheck,
    name: 'REGULATORS',
    description: 'Automated machine-to-machine validation at EU borders.',
    subdomain: 'verify.passr.eu',
    tag: 'ENFORCER',
    pos: { top: '240px', left: '0px' },
    width: '220px',
    apiBadge: true,
  },
  {
    id: 'suppliers',
    icon: Factory,
    name: 'SUPPLIERS',
    description: 'Upload lab reports, certify materials, attach data to SKUs.',
    subdomain: 'supplier.passr.eu',
    tag: 'DATA SOURCE',
    pos: { top: '240px', right: '0px' },
    width: '220px',
  },
  {
    id: 'recyclers',
    icon: Wrench,
    name: 'RECYCLERS',
    description: 'Access industrial teardown specs, hazardous material data.',
    subdomain: 'recycler.passr.eu',
    tag: 'END OF LIFE',
    pos: { bottom: '0px', left: '60px' },
    width: '220px',
  },
  {
    id: 'consumers',
    icon: Smartphone,
    name: 'CONSUMERS',
    description: 'Access product authenticity, materials, care instructions.',
    subdomain: 'verify.passr.eu',
    tag: 'END USER',
    pos: { bottom: '0px', right: '60px' },
    width: '220px',
  }
];

const stats = [
  { value: '5', label: 'STAKEHOLDER PORTALS' },
  { value: '2028', label: 'EU ENFORCEMENT DEADLINE', highlight: true },
  { value: 'GS1', label: 'DIGITAL LINK STANDARD' }
];
---

<section id="ecosystem" class="eco-section">
  <!-- Background Dotted Grid -->
  <div class="eco-grid-bg"></div>

  <div class="container-inner relative" style="z-index:1">
    <!-- ── FIX 1: Section Header ── -->
    <div class="ecosystem-header">
      <div class="ecosystem-eyebrow">
        <span class="eyebrow-bar"></span>
        <span class="eyebrow-text">THE PASSR ECOSYSTEM</span>
      </div>
      <h2 class="ecosystem-headline">
        One infrastructure.<br>
        Five stakeholders.<br>
        <span class="headline-accent">Zero gaps.</span>
      </h2>
      <p class="ecosystem-sub">
        Passr connects every party in the product compliance chain —
        from raw material supplier to end-of-life recycler.
      </p>
    </div>

    <!-- ── DESKTOP DIAGRAM ── -->
    <div class="diagram-viewport hidden lg:block">
      <div class="diagram-container">

        <!-- ── FIX 3 & 4: JS-drawn SVG connector layer ── -->
        <svg class="connector-svg" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:2;overflow:visible">
        </svg>

        <!-- ── FIX 3: Flow label divs (positioned by JS) ── -->
        <div id="label-node-brands" class="flow-label">PASSPORT DATA</div>
        <div id="label-node-regulators" class="flow-label">COMPLIANCE API</div>
        <div id="label-node-suppliers" class="flow-label">CERTIFICATIONS</div>
        <div id="label-node-recyclers" class="flow-label">TEARDOWN SPECS</div>
        <div id="label-node-consumers" class="flow-label">QR SCAN</div>

        <!-- ── FIX 2: Center Hub (72px wordmark) ── -->
        <div class="hub-center">
          <div class="hub-wordmark">PASSR<span class="hub-dot">●</span></div>
          <div class="hub-divider"></div>
          <span class="hub-subtitle">THE CONNECTED DPP ECOSYSTEM</span>
          <span class="hub-tag">EU ESPR · GS1 DIGITAL LINK</span>
        </div>

        <!-- ── FIX 2 & 3: Stakeholder Cards with IDs ── -->
        {nodes.map(node => (
          <div
            id={`node-${node.id}`}
            class="stakeholder-card"
            style={{...node.pos, width: node.width}}
          >
            <div class="card-top">
              <node.icon size={32} stroke-width={1.5} class="card-icon" />
              <div class="check-badge">
                <Check size={12} stroke-width={3} class="text-signal" />
              </div>
            </div>
            <h3 class="card-title">{node.name}</h3>
            <p class="card-desc">{node.description}</p>
            <!-- ── FIX 5: Card bottom row (no truncation) ── -->
            <div class="card-bottom-row">
              <span class="card-subdomain">{node.subdomain}</span>
              <div style="display:flex;align-items:center;gap:4px;flex-shrink:0">
                {node.apiBadge && <span class="api-badge">API</span>}
                <span class="card-tag">{node.tag}</span>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>

    <!-- ── MOBILE LAYOUT ── -->
    <div class="lg:hidden mobile-layout">
      <div class="mobile-hub">
        <div class="hub-wordmark-mobile">
          PASSR<span class="hub-dot">●</span>
        </div>
        <div class="hub-metadata-mobile">EU ESPR COMPLIANT DPP INFRASTRUCTURE</div>
      </div>
      <div class="mobile-connector-line"></div>
      <div class="mobile-cards-container">
        {nodes.map(node => (
          <div class="mobile-card">
            <div class="card-top">
              <node.icon size={28} stroke-width={1.5} class="card-icon" />
              <div class="check-badge">
                <Check size={12} stroke-width={3} class="text-signal" />
              </div>
            </div>
            <h3 class="card-title">{node.name}</h3>
            <p class="card-desc">{node.description}</p>
            <div class="card-bottom-row">
              <span class="card-subdomain">{node.subdomain}</span>
              <span class="card-tag">{node.tag}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── STATS SECTION ── -->
    <div class="stat-grid">
      {stats.map(stat => (
        <div class="stat-item">
          <div class={`stat-value ${stat.highlight ? 'stat-value-accent' : ''}`}>
            {stat.value}
          </div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── FIX 6: Section with dot grid texture ── */
  .eco-section {
    background: #F8F8F8;
    padding: 120px 0;
    overflow: hidden;
    position: relative;
  }

  .eco-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, #C8C8C8 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.4;
  }

  .text-signal { color: #FF3B30; }

  /* ── FIX 1: Section Header ── */
  .ecosystem-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 80px auto;
    position: relative;
    z-index: 1;
  }

  .ecosystem-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .eyebrow-bar {
    display: inline-block;
    width: 2px;
    height: 18px;
    background: #FF3B30;
    flex-shrink: 0;
  }

  .eyebrow-text {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #909090;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .ecosystem-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 1.0;
    color: #0A0A0A;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .headline-accent {
    color: #FF3B30;
  }

  .ecosystem-sub {
    font-family: 'Roboto Mono', monospace;
    font-size: 13px;
    color: #909090;
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── DIAGRAM ── */
  .diagram-viewport {
    margin-top: 40px;
    position: relative;
    z-index: 1;
  }

  /* ── FIX 7: Diagram container positioning ── */
  .diagram-container {
    position: relative;
    width: 100%;
    max-width: 1000px;
    height: 760px;
    margin: 0 auto;
    z-index: 1;
  }

  /* ── FIX 2: Center Hub ── */
  .hub-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 3;
    min-width: 200px;
  }

  .hub-wordmark {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 72px;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #0A0A0A;
  }

  .hub-dot {
    color: #FF3B30;
    font-size: 14px;
    vertical-align: super;
    margin-left: 4px;
  }

  .hub-divider {
    width: 40px;
    height: 1px;
    background: #E0E0E0;
    margin: 12px auto;
  }

  .hub-subtitle {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #909090;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
    display: block;
  }

  .hub-tag {
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #CCCCCC;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
    display: block;
  }

  /* ── FIX 7: Stakeholder Cards z-index ── */
  .stakeholder-card {
    position: absolute;
    background: #FFFFFF;
    border: 1px solid #E8E8E8;
    border-radius: 2px;
    padding: 20px;
    z-index: 3;
    transition: border-color 150ms ease;
    display: flex;
    flex-direction: column;
    min-height: 200px;
  }

  .stakeholder-card:hover {
    border-color: #D0D0D0;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .card-icon { color: #0A0A0A; }

  .check-badge {
    width: 20px;
    height: 20px;
    border: 1px solid #FF3B30;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: #0A0A0A;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 8px;
    flex-shrink: 0;
  }

  .card-desc {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #585858;
    line-height: 1.5;
    margin-bottom: 16px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── FIX 5: Card bottom row (no truncation) ── */
  .card-bottom-row {
    border-top: 1px solid #F0F0F0;
    padding-top: 10px;
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 6px;
    flex-wrap: nowrap;
    flex-shrink: 0;
  }

  .card-subdomain {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #AAAAAA;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  /* ── FIX 5: Tag — no max-width, no overflow hidden, smaller font ── */
  .card-tag {
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #FF3B30;
    border: 1px solid #FFE0DE;
    padding: 2px 5px;
    white-space: nowrap;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .api-badge {
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #AAAAAA;
    border: 1px solid #E8E8E8;
    padding: 2px 5px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ── FIX 3 & 4: Flow Labels (positioned by JS) ── */
  .flow-label {
    position: absolute;
    background: #FFFFFF;
    border: 1px solid #E8E8E8;
    padding: 3px 10px;
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #AAAAAA;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    z-index: 4;
    pointer-events: none;
    /* Hidden until JS positions them */
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* ── STATS ── */
  .stat-grid {
    margin: 48px auto 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    background: #E8E8E8;
    border: 1px solid #E8E8E8;
    max-width: 1000px;
    position: relative;
    z-index: 1;
  }

  .stat-item {
    background: #FFFFFF;
    padding: 24px 32px;
    text-align: center;
    border: 1px solid #E8E8E8;
    margin: -1px;
  }

  .stat-value {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 44px;
    line-height: 1;
    color: #0A0A0A;
  }

  .stat-value-accent { color: #FF3B30 !important; }

  .stat-label {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #AAAAAA;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 8px;
  }

  /* ── MOBILE ── */
  .mobile-layout {
    margin-top: 48px;
    position: relative;
    z-index: 1;
  }

  .mobile-hub {
    background: #0A0A0A;
    border: 1px solid #FF3B30;
    padding: 28px;
    text-align: center;
    border-radius: 2px;
  }

  .hub-wordmark-mobile {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 36px;
    color: #FFFFFF;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .hub-metadata-mobile {
    margin-top: 8px;
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #858585;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .mobile-connector-line {
    width: 1px;
    height: 40px;
    border-left: 1px dashed #E0E0E0;
    margin: 0 0 0 40px;
  }

  .mobile-cards-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-left: 1px dashed #E0E0E0;
    margin-left: 40px;
    padding-left: 20px;
  }

  .mobile-card {
    background: #FFFFFF;
    border: 1px solid #E8E8E8;
    border-left: 3px solid #FF3B30;
    border-radius: 2px;
    padding: 24px;
    width: 100%;
  }

  @media (max-width: 1023px) {
    .stat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- ── FIX 3 & 4: JS-drawn connectors ── -->
<script>
  function drawConnectors() {
    const container = document.querySelector('.diagram-container') as HTMLElement;
    const svg = document.querySelector('.connector-svg') as unknown as SVGSVGElement;
    const hub = document.querySelector('.hub-center') as HTMLElement;

    if (!container || !svg || !hub) return;

    const containerRect = container.getBoundingClientRect();
    const hubRect = hub.getBoundingClientRect();

    // Hub center point (relative to container)
    const hx = hubRect.left - containerRect.left + hubRect.width / 2;
    const hy = hubRect.top - containerRect.top + hubRect.height / 2;

    const nodes = [
      { id: 'node-brands',     label: 'PASSPORT DATA',  edge: 'bottom' as const },
      { id: 'node-regulators', label: 'COMPLIANCE API', edge: 'right'  as const },
      { id: 'node-suppliers',  label: 'CERTIFICATIONS', edge: 'left'   as const },
      { id: 'node-recyclers',  label: 'TEARDOWN SPECS', edge: 'top'    as const },
      { id: 'node-consumers',  label: 'QR SCAN',        edge: 'top'    as const },
    ];

    // Clear existing paths
    svg.innerHTML = '';

    nodes.forEach((node, i) => {
      const el = document.getElementById(node.id);
      if (!el) return;

      const r = el.getBoundingClientRect();

      // Calculate card edge midpoint based on which edge faces center
      let ex: number, ey: number;
      switch (node.edge) {
        case 'bottom':
          ex = r.left - containerRect.left + r.width / 2;
          ey = r.bottom - containerRect.top;
          break;
        case 'right':
          ex = r.right - containerRect.left;
          ey = r.top - containerRect.top + r.height / 2;
          break;
        case 'left':
          ex = r.left - containerRect.left;
          ey = r.top - containerRect.top + r.height / 2;
          break;
        case 'top':
        default:
          ex = r.left - containerRect.left + r.width / 2;
          ey = r.top - containerRect.top;
          break;
      }

      // Calculate hub edge point facing this node
      const angle = Math.atan2(ey - hy, ex - hx);
      const hubEdgeX = hx + Math.cos(angle) * 60;
      const hubEdgeY = hy + Math.sin(angle) * 30;

      // Create L-shaped path with one waypoint
      let pathD: string;
      if (node.edge === 'bottom' || node.edge === 'top') {
        pathD = `M ${hubEdgeX},${hubEdgeY} L ${ex},${hubEdgeY} L ${ex},${ey}`;
      } else {
        pathD = `M ${hubEdgeX},${hubEdgeY} L ${hubEdgeX},${ey} L ${ex},${ey}`;
      }

      // Draw the path
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', pathD);
      path.setAttribute('id', `path-${node.id}`);
      path.setAttribute('stroke', '#CCCCCC');
      path.setAttribute('stroke-width', '1.5');
      path.setAttribute('stroke-dasharray', '5 4');
      path.setAttribute('fill', 'none');
      svg.appendChild(path);

      // Add bend point dot (at first corner)
      const pathLength = path.getTotalLength();
      const cornerPt = path.getPointAtLength(pathLength * 0.5);

      const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('cx', String(cornerPt.x));
      dot.setAttribute('cy', String(cornerPt.y));
      dot.setAttribute('r', '4');
      dot.setAttribute('fill', '#FF3B30');
      svg.appendChild(dot);

      // Animated outbound particle
      const circle1 = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle1.setAttribute('r', '3');
      circle1.setAttribute('fill', '#FF3B30');
      circle1.setAttribute('opacity', '0.9');
      const anim1 = document.createElementNS('http://www.w3.org/2000/svg', 'animateMotion');
      anim1.setAttribute('dur', '2.5s');
      anim1.setAttribute('repeatCount', 'indefinite');
      anim1.setAttribute('begin', `${i * 0.5}s`);
      const mpath1 = document.createElementNS('http://www.w3.org/2000/svg', 'mpath');
      mpath1.setAttributeNS('http://www.w3.org/1999/xlink', 'href', `#path-${node.id}`);
      anim1.appendChild(mpath1);
      circle1.appendChild(anim1);
      svg.appendChild(circle1);

      // Animated inbound particle
      const circle2 = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle2.setAttribute('r', '2.5');
      circle2.setAttribute('fill', '#FF3B30');
      circle2.setAttribute('opacity', '0.4');
      const anim2 = document.createElementNS('http://www.w3.org/2000/svg', 'animateMotion');
      anim2.setAttribute('dur', '2.5s');
      anim2.setAttribute('repeatCount', 'indefinite');
      anim2.setAttribute('begin', `${i * 0.5 + 1.25}s`);
      anim2.setAttribute('keyPoints', '1;0');
      anim2.setAttribute('keyTimes', '0;1');
      anim2.setAttribute('calcMode', 'linear');
      const mpath2 = document.createElementNS('http://www.w3.org/2000/svg', 'mpath');
      mpath2.setAttributeNS('http://www.w3.org/1999/xlink', 'href', `#path-${node.id}`);
      anim2.appendChild(mpath2);
      circle2.appendChild(anim2);
      svg.appendChild(circle2);

      // Position flow label at midpoint of path
      const labelEl = document.getElementById(`label-${node.id}`);
      if (labelEl) {
        const midPoint = path.getPointAtLength(pathLength * 0.45);
        labelEl.style.left = (midPoint.x - labelEl.offsetWidth / 2) + 'px';
        labelEl.style.top = (midPoint.y - 12) + 'px';
        labelEl.style.opacity = '1';
      }
    });
  }

  if (document.readyState === 'complete') {
    setTimeout(drawConnectors, 150);
  } else {
    window.addEventListener('load', () => setTimeout(drawConnectors, 150));
  }

  window.addEventListener('resize', drawConnectors);
</script>
