---
import { Shirt, ShieldCheck, Factory, Wrench, Smartphone, Check } from '@lucide/astro';

const nodes = [
  {
    id: 'brands',
    icon: Shirt,
    name: 'BRANDS',
    description: 'Manage product lines, oversee compliance, generate QR codes.',
    subdomain: 'app.passr.eu',
    tag: 'PAYING CLIENT',
    pos: { top: '0px', left: '50%', transform: 'translateX(-50%)' },
    width: '220px',
    pathId: 'path-brands',
    d: 'M 500,350 L 500,200',
    dots: [],
    begin: '0s'
  },
  {
    id: 'regulators',
    icon: ShieldCheck,
    name: 'REGULATORS',
    description: 'Automated machine-to-machine validation at EU borders.',
    subdomain: 'verify.passr.eu',
    tag: 'ENFORCER',
    pos: { top: '240px', left: '0px' },
    width: '220px',
    apiBadge: true,
    pathId: 'path-regulators',
    d: 'M 420,380 L 320,380 L 320,350 L 220,350',
    dots: [{x: 320, y: 380}, {x: 320, y: 350}],
    begin: '0.4s'
  },
  {
    id: 'suppliers',
    icon: Factory,
    name: 'SUPPLIERS',
    description: 'Upload lab reports, certify materials, attach data to SKUs.',
    subdomain: 'supplier.passr.eu',
    tag: 'DATA SOURCE',
    pos: { top: '240px', right: '0px' },
    width: '220px',
    pathId: 'path-suppliers',
    d: 'M 580,380 L 680,380 L 680,350 L 780,350',
    dots: [{x: 680, y: 380}, {x: 680, y: 350}],
    begin: '0.8s'
  },
  {
    id: 'recyclers',
    icon: Wrench,
    name: 'RECYCLERS',
    description: 'Access industrial teardown specs, hazardous material data.',
    subdomain: 'recycler.passr.eu',
    tag: 'END OF LIFE',
    pos: { bottom: '0px', left: '60px' },
    width: '220px',
    pathId: 'path-recyclers',
    d: 'M 460,420 L 460,520 L 280,520 L 280,580',
    dots: [{x: 460, y: 520}, {x: 280, y: 520}],
    begin: '1.2s'
  },
  {
    id: 'consumers',
    icon: Smartphone,
    name: 'CONSUMERS',
    description: 'Access product authenticity, materials, care instructions.',
    subdomain: 'verify.passr.eu',
    tag: 'END USER',
    pos: { bottom: '0px', right: '60px' },
    width: '220px',
    pathId: 'path-consumers',
    d: 'M 540,420 L 540,520 L 720,520 L 720,580',
    dots: [{x: 540, y: 520}, {x: 720, y: 520}],
    begin: '1.6s'
  }
];

const flowLabels = [
  { text: 'PASSPORT DATA', style: 'top: 140px; left: 50%; transform: translateX(-50%)' },
  { text: 'COMPLIANCE API', style: 'top: 360px; left: 260px' },
  { text: 'CERTIFICATIONS', style: 'top: 360px; right: 260px' },
  { text: 'TEARDOWN SPECS', style: 'bottom: 180px; left: 330px' },
  { text: 'QR SCAN', style: 'bottom: 180px; right: 300px' }
];

const stats = [
  { value: '5', label: 'STAKEHOLDER PORTALS' },
  { value: '2028', label: 'EU ENFORCEMENT DEADLINE', highlight: true },
  { value: 'GS1', label: 'DIGITAL LINK STANDARD' }
];
---

<section id="ecosystem" class="eco-section">
  <!-- Background Dotted Grid -->
  <div class="eco-grid-bg"></div>

  <div class="container-inner relative z-10">
    <!-- Section Header -->
    <header class="eco-header">
      <div class="eco-eyebrow">
        <span class="eyebrow-bar"></span>
        THE PASSR ECOSYSTEM
      </div>
      <h2 class="eco-headline">
        One infrastructure.<br />
        Five stakeholders.<br />
        <span class="text-signal">Zero gaps.</span>
      </h2>
      <p class="eco-subheadline">
        Passr connects every party in the product compliance chain —<br />
        from raw material supplier to end-of-life recycler.
      </p>
    </header>

    <!-- ── DESKTOP DIAGRAM ── -->
    <div class="diagram-viewport hidden lg:block">
      <div class="diagram-container">
        <!-- SVG Connections -->
        <svg class="connections-svg" width="1000" height="760" viewBox="0 0 1000 760" fill="none" xmlns="http://www.w3.org/2000/svg">
          {nodes.map(node => (
            <path id={node.pathId} d={node.d} class="connector-path" />
          ))}

          <!-- Static Connection Dots at Bends -->
          {nodes.flatMap(node => node.dots.map(dot => (
            <circle cx={dot.x} cy={dot.y} r="4" fill="#FF3B30" />
          )))}

          <!-- Animated Particles -->
          {nodes.map(node => (
            <g>
              <!-- Outbound -->
              <circle r="3" fill="#FF3B30" opacity="0.9">
                <animateMotion dur="2.5s" repeatCount="indefinite" calcMode="linear" begin={node.begin}>
                  <mpath href={`#${node.pathId}`} />
                </animateMotion>
              </circle>
              <!-- Inbound -->
              <circle r="2.5" fill="#FF3B30" opacity="0.4">
                <animateMotion dur="2.5s" repeatCount="indefinite" calcMode="linear" begin={node.begin} keyPoints="1;0" keyTimes="0;1">
                  <mpath href={`#${node.pathId}`} />
                </animateMotion>
              </circle>
            </g>
          ))}
        </svg>

        <!-- Center Hub -->
        <div class="center-hub">
          <div class="hub-wordmark">
            PASSR<span class="hub-dot">●</span>
          </div>
          <div class="hub-subtitle">THE CONNECTED DPP ECOSYSTEM</div>
          <div class="hub-metadata">EU ESPR · GS1 DIGITAL LINK</div>
        </div>

        <!-- Stakeholder Cards -->
        {nodes.map(node => (
          <div class="stakeholder-card" style={{...node.pos, width: node.width}}>
            <div class="card-top">
              <node.icon size={32} stroke-width={1.5} class="card-icon" />
              <div class="check-badge">
                <Check size={12} stroke-width={3} class="text-signal" />
              </div>
            </div>
            <h3 class="card-title">{node.name}</h3>
            <p class="card-desc">{node.description}</p>
            <div class="card-bottom">
              <span class="card-subdomain">{node.subdomain}</span>
              <div class="flex items-center gap-2 shrink-0">
                {node.apiBadge && <span class="api-badge">API</span>}
                <span class="role-tag" title={node.tag}>{node.tag}</span>
              </div>
            </div>
          </div>
        ))}

        <!-- Data Flow Labels -->
        {flowLabels.map(label => (
          <div class="flow-label" style={label.style}>
            {label.text}
          </div>
        ))}
      </div>
    </div>

    <!-- ── MOBILE LAYOUT ── -->
    <div class="lg:hidden mobile-layout">
      <!-- Mobile Hub -->
      <div class="mobile-hub">
        <div class="hub-wordmark text-white">
          PASSR<span class="hub-dot">●</span>
        </div>
        <div class="hub-metadata text-[#858585] mt-2">
          EU ESPR COMPLIANT DPP INFRASTRUCTURE
        </div>
      </div>

      <!-- Vertical Connective Line -->
      <div class="mobile-connector-line"></div>

      <!-- Mobile Cards -->
      <div class="mobile-cards-container">
        {nodes.map(node => (
          <div class="mobile-card">
            <div class="card-top">
              <node.icon size={28} stroke-width={1.5} class="card-icon" />
              <div class="check-badge">
                <Check size={12} stroke-width={3} class="text-signal" />
              </div>
            </div>
            <h3 class="card-title">{node.name}</h3>
            <p class="card-desc">{node.description}</p>
            <div class="card-bottom">
              <span class="card-subdomain">{node.subdomain}</span>
              <span class="role-tag">{node.tag}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── STATS SECTION ── -->
    <div class="stat-grid">
      {stats.map(stat => (
        <div class="stat-item">
          <div class={`stat-value ${stat.highlight ? 'text-signal' : 'text-[#0A0A0A]'}`}>
            {stat.value}
          </div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .eco-section {
    background: #F8F8F8;
    padding: 120px 0;
    overflow: hidden;
    position: relative;
  }

  /* Dot Grid Background */
  .eco-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, #CCCCCC 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.5;
  }

  .text-signal { color: #FF3B30; }

  /* ── HEADER ── */
  .eco-header {
    max-width: 640px;
    margin: 0 auto 72px auto;
    text-align: center;
  }

  .eco-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
    margin-bottom: 16px;
    font-family: 'Roboto Mono', monospace !important;
    font-size: 11px;
    color: #909090;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eyebrow-bar {
    width: 2px;
    height: 18px;
    background: #FF3B30;
  }

  .eco-headline {
    font-family: 'Space Grotesk', sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(36px, 4vw, 52px);
    color: #0A0A0A;
    line-height: 1.0;
    text-transform: uppercase;
  }

  .eco-subheadline {
    margin-top: 16px;
    font-family: 'Roboto Mono', monospace;
    font-size: 13px;
    color: #909090;
    line-height: 1.7;
  }

  /* ── DIAGRAM ── */
  .diagram-viewport {
    margin-top: 40px;
  }

  .diagram-container {
    position: relative;
    width: 100%;
    max-width: 1000px;
    height: 760px;
    margin: 0 auto;
  }

  .connections-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  .connector-path {
    stroke: #CCCCCC;
    stroke-width: 1.5;
    fill: none;
    stroke-dasharray: 5 4;
  }

  /* Center Hub */
  .center-hub {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 20;
    min-width: 180px;
    padding: 20px;
    background: transparent;
  }

  .hub-wordmark {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 56px;
    color: #0A0A0A;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .hub-dot {
    color: #FF3B30;
    font-size: 12px;
    vertical-align: super;
    margin-left: 3px;
  }

  .hub-subtitle {
    margin-top: 10px;
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #909090;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
  }

  .hub-metadata {
    margin-top: 4px;
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #BBBBBB;
    letter-spacing: 0.02em;
    display: block;
  }

  /* Stakeholder Cards */
  .stakeholder-card {
    position: absolute;
    background: #FFFFFF;
    border: 1px solid #E8E8E8;
    border-radius: 2px;
    padding: 20px;
    z-index: 30;
    transition: border-color 150ms ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 200px;
  }

  .stakeholder-card:hover {
    border-color: #D0D0D0;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .card-icon {
    color: #0A0A0A;
  }

  .check-badge {
    width: 20px;
    height: 20px;
    border: 1px solid #FF3B30;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: #0A0A0A;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 8px;
    flex-shrink: 0;
  }

  .card-desc {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #585858;
    line-height: 1.5;
    margin-bottom: 16px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-bottom {
    border-top: 1px solid #F0F0F0;
    padding-top: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    flex-wrap: nowrap;
    gap: 8px;
    flex-shrink: 0;
  }

  .card-subdomain {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #AAAAAA;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .role-tag {
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    font-weight: 500;
    color: #FF3B30;
    text-transform: uppercase;
    background: #FFFFFF;
    border: 1px solid #FFE0DE;
    padding: 2px 6px;
    white-space: nowrap;
    flex-shrink: 0;
    max-width: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .api-badge {
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #AAAAAA;
    border: 1px solid #E8E8E8;
    padding: 2px 6px;
    flex-shrink: 0;
  }

  /* Flow Labels */
  .flow-label {
    position: absolute;
    background: #FFFFFF;
    border: 1px solid #EBEBEB;
    padding: 3px 10px;
    font-family: 'Roboto Mono', monospace;
    font-size: 9px;
    color: #AAAAAA;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    z-index: 40;
    pointer-events: none;
  }

  /* ── STATS ── */
  .stat-grid {
    margin: 48px auto 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    background: #E8E8E8;
    border: 1px solid #E8E8E8;
    max-width: 1000px;
  }

  .stat-item {
    background: #FFFFFF;
    padding: 24px 32px;
    text-align: center;
    border: 1px solid #E8E8E8;
    margin: -1px;
  }

  .stat-value {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 44px;
    line-height: 1;
  }

  .stat-label {
    font-family: 'Roboto Mono', monospace;
    font-size: 10px;
    color: #AAAAAA;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 8px;
  }

  /* ── MOBILE ── */
  .mobile-layout {
    margin-top: 48px;
  }

  .mobile-hub {
    background: #0A0A0A;
    border: 1px solid #FF3B30;
    padding: 28px;
    text-align: center;
    border-radius: 2px;
  }

  .mobile-connector-line {
    width: 1px;
    height: 40px;
    border-left: 1px dashed #E0E0E0;
    margin: 0 0 0 40px;
  }

  .mobile-cards-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-left: 1px dashed #E0E0E0;
    margin-left: 40px;
    padding-left: 20px;
  }

  .mobile-card {
    background: #FFFFFF;
    border: 1px solid #E8E8E8;
    border-left: 3px solid #FF3B30;
    border-radius: 2px;
    padding: 24px;
    width: 100%;
  }

  @media (max-width: 1023px) {
    .stat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
