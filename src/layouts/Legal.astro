---
import Base from './Base.astro';
import '../styles/legal.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Legal documentation for Passr." } = Astro.props;
const currentYear = new Date().getFullYear();
---

<Base title={title} description={description}>
	<div class="legal-page min-h-screen selection:bg-[var(--color-signal)] selection:text-white">
		<nav class="py-16 border-b border-black/10">
			<div class="max-w-[760px] mx-auto px-6 flex items-center justify-between">
				<a href="/" class="flex items-center group">
					<img src="/brand-assets/passr-logo-optimized.webp" alt="Passr Logo" style="height: 150px;" class="w-auto block" />
				</a>
				<a href="/#waitlist" class="font-display font-semibold text-xs tracking-widest uppercase text-void hover:text-signal transition-colors">
					Pilot Program →
				</a>
			</div>
		</nav>

		<main class="max-w-[760px] mx-auto px-6 py-20">
			<article class="legal-content">
				<slot />
			</article>
		</main>

		<footer class="max-w-[760px] mx-auto px-6 py-12 border-t border-black/10">
			<div class="flex justify-between items-center font-mono text-[10px] uppercase text-metal">
				<span>© {currentYear} Hisako Technologies OÜ / Passr</span>
				<span>Legal Protocol v1.2</span>
			</div>
		</footer>
	</div>
</Base>
